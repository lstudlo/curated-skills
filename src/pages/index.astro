---
import Layout from '../layouts/Layout.astro';
import SkillCard from '../components/SkillCard.astro';
import { getSkills } from '../lib/skills';

export const prerender = true;

const skills = await getSkills();
const documentingSkill = skills.find((skill) => skill.slug === 'documenting') ?? null;
---

<Layout
  title="Curated Skills"
  description="Browse, inspect, and download public coding-agent skills and supporting scripts."
>
  <section>
    <div class="rounded-4xl border border-zinc-200 bg-white/75 p-6 shadow-xl backdrop-blur sm:p-8 dark:border-zinc-800 dark:bg-zinc-950/70">
      <p class="text-[11px] tracking-[0.18em] text-zinc-500 uppercase">Skill Library</p>
      <h1 class="mt-3 max-w-3xl font-serif text-4xl leading-tight tracking-tight sm:text-5xl">
        An index of coding-agent skills used by lstudlo.
      </h1>
      <p class="mt-4 max-w-2xl text-sm leading-6 text-zinc-600 dark:text-zinc-300">
        Every skill in <code class="font-mono">src/skills</code> is listed here with metadata, file browsing, and direct downloads for docs, scripts, and references.
      </p>
      <div class="mt-8 flex flex-wrap gap-2">
        <a
          href="#skills"
          class="rounded-full border border-[var(--accent)] bg-[var(--accent)] px-4 py-2 text-xs tracking-[0.16em] text-white uppercase transition hover:opacity-90 dark:text-zinc-950"
        >
          Explore Skills
        </a>
        {documentingSkill && (
          <a
            href={`/skills/${encodeURIComponent(documentingSkill.slug)}/`}
            class="rounded-full border border-zinc-300/80 px-4 py-2 text-xs tracking-[0.16em] uppercase hover:bg-zinc-100 dark:border-zinc-700 dark:hover:bg-zinc-900"
          >
            Featured: Documenting
          </a>
        )}
      </div>
    </div>
  </section>

  {documentingSkill && (
    <section class="mt-10">
      <div class="grid gap-4 lg:grid-cols-[minmax(0,1.6fr)_minmax(0,1fr)]">
        <article class="rounded-4xl border border-zinc-200 bg-white/80 p-6 shadow-xl backdrop-blur sm:p-8 dark:border-zinc-800 dark:bg-zinc-950/70">
          <p class="text-[11px] tracking-[0.18em] text-zinc-500 uppercase">New Skill</p>
          <h2 class="mt-3 max-w-2xl font-serif text-3xl leading-tight tracking-tight sm:text-4xl">
            Write tighter feature specs and technical design docs with the documenting skill.
          </h2>
          <p class="mt-4 max-w-2xl text-sm leading-6 text-zinc-600 dark:text-zinc-300">
            {documentingSkill.description}
          </p>
          <div class="mt-6 flex flex-wrap gap-2">
            <a
              href={`/skills/${encodeURIComponent(documentingSkill.slug)}/`}
              class="rounded-full border border-[var(--accent)] bg-[var(--accent)] px-4 py-2 text-xs tracking-[0.16em] text-white uppercase transition hover:opacity-90 dark:text-zinc-950"
            >
              Open Skill Page
            </a>
            <a
              href={`/download-skill/${encodeURIComponent(documentingSkill.slug)}.zip`}
              download
              class="rounded-full border border-zinc-300/80 px-4 py-2 text-xs tracking-[0.16em] uppercase hover:bg-zinc-100 dark:border-zinc-700 dark:hover:bg-zinc-900"
            >
              Download ZIP
            </a>
          </div>
        </article>

        <aside class="rounded-4xl border border-zinc-200/80 bg-zinc-50/70 p-6 backdrop-blur dark:border-zinc-800 dark:bg-zinc-900/50">
          <p class="text-[11px] tracking-[0.16em] text-zinc-500 uppercase">What’s Inside</p>
          <ul class="mt-4 space-y-3 text-sm leading-6 text-zinc-700 dark:text-zinc-300">
            <li>Short, reviewable templates for feature specs and technical design docs.</li>
            <li>Explicit doc path rules for <code class="font-mono">/docs/features</code> and <code class="font-mono">/docs/technical</code>.</li>
            <li>A concision checklist to cut filler before a doc is shared for review.</li>
          </ul>
        </aside>
      </div>
    </section>
  )}

  <section id="skills" class="mt-10">
    <div class="mb-4 flex items-end justify-between gap-4 px-1">
      <div>
        <p class="text-[11px] tracking-[0.16em] text-zinc-500 uppercase">All Skills</p>
        <h2 class="mt-1 font-serif text-2xl tracking-tight sm:text-3xl">Browse and inspect every skill package</h2>
      </div>
      <p class="hidden text-xs text-zinc-500 md:block">
        Click any card to inspect files and download scripts/docs.
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {skills.map((skill) => <SkillCard skill={skill} />)}
    </div>
  </section>
</Layout>
